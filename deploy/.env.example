# Production environment for the tbr systemd service.
# Install at /opt/tbr/.env, owned by tbr:tbr, mode 640.
#   sudo install -o tbr -g tbr -m 640 .env.example /opt/tbr/.env
# Then edit /opt/tbr/.env and fill in the real JDBC URL.
#
# This file is read by systemd's EnvironmentFile= directive — DO NOT
# add `export` keywords or shell quoting; just KEY=value pairs.

SPRING_PROFILES_ACTIVE=prod

# Neon Postgres JDBC URL. Format:
#   jdbc:postgresql://HOST/DB?sslmode=require&user=USER&password=PASS
# Use the direct host, not the -pooler host (PgBouncer breaks Hibernate's
# prepared-statement caching during first-boot schema creation).
JDBC_DATABASE_URL=jdbc:postgresql://HOST/DB?sslmode=require&user=USER&password=PASS
